# hiai-docs Docker Compose (Development) — TEMPLATE
#
# Copy this file to docker-compose.dev.yml and fill in your local values:
#   cp docker-compose.dev.yml.example docker-compose.dev.yml
#
# The .example file is tracked in git; the actual docker-compose.dev.yml is
# gitignored. Adjust secrets, ports, and embedding provider settings for your
# machine, then `docker compose -f docker-compose.dev.yml up`.

services:
  # Postgres with the pgvector extension. Stores documents, chunks,
  # embeddings, and Better Auth state.
  postgres:
    image: pgvector/pgvector:pg18
    restart: unless-stopped
    ports:
      - "${DB_PORT:-5437}:5432"
    volumes:
      - pgdata:/var/lib/postgresql
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    environment:
      POSTGRES_DB: ${DB_NAME:-hiai_docs}
      POSTGRES_USER: ${DB_USER:-aiuser}
      # Change this for any non-throwaway environment.
      POSTGRES_PASSWORD: ${DB_PASSWORD:-changeme}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-aiuser} -d ${DB_NAME:-hiai_docs}"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: "2"

  # Redis — used for caching, rate limiting, and job queues.
  redis:
    image: redis:8-alpine
    restart: unless-stopped
    ports:
      - "${REDIS_PORT:-6384}:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"

  # MinIO — S3-compatible object storage for uploaded files (PDFs, etc.).
  # The fixed 9020/9021 host ports avoid clashing with ai-shared-minio (9010/9011).
  minio:
    image: minio/minio:latest
    restart: unless-stopped
    ports:
      - "9020:9000"
      - "9021:9001"
    volumes:
      - minio_data:/data
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ACCESS_KEY:-minioadmin}
      MINIO_ROOT_PASSWORD: ${MINIO_SECRET_KEY:-minioadmin}
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"

  # Backend API (Bun + Hono). Runs db:push on start, then watches src/.
  api:
    image: oven/bun:1.3.14-alpine
    working_dir: /mnt/ai_data/projects/hiai-docs
    restart: unless-stopped
    ports:
      - "${API_PORT:-50700}:50700"
    volumes:
      # Bind-mount source for live reload.
      # Host's node_modules (with workspace symlinks) are used directly.
      - ./:/mnt/ai_data/projects/hiai-docs
      - ../../packages/hiai-ui:/mnt/ai_data/packages/hiai-ui
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
    command:
      - sh
      - -c
      - "cd /mnt/ai_data/projects/hiai-docs/packages/db && bun run db:push && cd /mnt/ai_data/projects/hiai-docs/backend && bun run --watch src/index.ts"
    env_file: .env
    environment:
      DATABASE_URL: postgresql://${DB_USER:-aiuser}:${DB_PASSWORD:-changeme}@postgres:5432/${DB_NAME:-hiai_docs}
      REDIS_URL: redis://redis:6379
      MINIO_ENDPOINT: minio
      MINIO_PORT: 9000
      MINIO_ACCESS_KEY: ${MINIO_ACCESS_KEY:-minioadmin}
      MINIO_SECRET_KEY: ${MINIO_SECRET_KEY:-minioadmin}
      MINIO_BUCKET: ${MINIO_BUCKET:-hiai-docs}
      MINIO_PUBLIC_ENDPOINT: localhost
      MINIO_PUBLIC_PORT: 9020
      BETTER_AUTH_SECRET: ${BETTER_AUTH_SECRET:-dev-only-secret-replace-me}
      BETTER_AUTH_URL: ${BETTER_AUTH_URL:-http://localhost:50700}
      CORS_ORIGINS: ${CORS_ORIGINS:-http://localhost:50701,http://127.0.0.1:50701}
      # Embedding provider (OpenAI-compatible). Leave the *_FALLBACK_* values
      # empty to disable the secondary provider. Required for ingestion.
      EMBEDDING_BASE_URL: ${EMBEDDING_BASE_URL:-}
      EMBEDDING_API_KEY: ${EMBEDDING_API_KEY:-}
      EMBEDDING_MODEL: ${EMBEDDING_MODEL:-}
      EMBEDDING_FALLBACK_BASE_URL: ${EMBEDDING_FALLBACK_BASE_URL:-}
      EMBEDDING_FALLBACK_API_KEY: ${EMBEDDING_FALLBACK_API_KEY:-}
      EMBEDDING_FALLBACK_MODEL: ${EMBEDDING_FALLBACK_MODEL:-}
      API_PORT: ${API_PORT:-50700}
      NODE_ENV: development
      LOG_LEVEL: ${LOG_LEVEL:-debug}
      # Loaded from .env; explicit here for Docker (Bun's auto-load only
      # checks the cwd, which after `cd /app/backend` is backend/).
      HIAI_DOCS_API_KEY: ${HIAI_DOCS_API_KEY:-}
      OWNER_ID: ${OWNER_ID:-api-key-user}
      CSRF_SECRET: ${CSRF_SECRET:-dev-csrf-change-in-production}
      WEBHOOK_SECRET: ${WEBHOOK_SECRET:-dev-webhook-change-in-production}
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"

  # SvelteKit frontend (Vite dev server).
  web:
    image: oven/bun:1.3.14-alpine
    working_dir: /mnt/ai_data/projects/hiai-docs
    restart: unless-stopped
    ports:
      - "${WEB_PORT:-50701}:50701"
    volumes:
      - ./:/mnt/ai_data/projects/hiai-docs
      - ../../packages/hiai-ui:/mnt/ai_data/packages/hiai-ui
    depends_on:
      - api
    command:
      - sh
      - -c
      - "cd /mnt/ai_data/projects/hiai-docs/frontend && bun run dev"
    environment:
      API_URL: http://api:${API_PORT:-50700}
      PORT: ${WEB_PORT:-50701}
      WEB_PORT: ${WEB_PORT:-50701}
      NODE_ENV: development

volumes:
  pgdata:
  redis_data:
  minio_data:
